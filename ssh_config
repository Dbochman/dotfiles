# Machine-local overrides (not tracked in dotfiles). First-match-wins,
# so anything in config.local takes precedence over blocks below.
Include ~/.ssh/config.local

# Dylan's Mac (via Tailscale)
Host dylans-mac
  HostName dylans-mac.tail3e55f9.ts.net
  User dylanbochman

# Mac Mini (via Tailscale)
Host dylans-mac-mini
  HostName dylans-mac-mini
  User dbochman

# Mac Mini alias with dedicated key (bypasses 1Password)
Host mac-mini
  HostName dylans-mac-mini.tail3e55f9.ts.net
  User dbochman
  IdentityFile ~/.ssh/id_mac_mini
  IdentitiesOnly yes
  IdentityAgent none

# MacBook Pro at 19 Crosstown (via Tailscale)
Host dylans-macbook-pro
  HostName 100.107.209.85
  User dbochman

# Direct Crosstown access with a machine-specific key.
Host crosstown-mac
  HostName 100.107.209.85
  User dbochman
  IdentityFile ~/.ssh/id_crosstown
  IdentitiesOnly yes
  IdentityAgent none

# Work MacBook Pro (via Tailscale)
Host dylans-work-mbp
  HostName 100.73.15.5
  User dbochman

# Short alias for the work laptop bastion.
Host work-mac
  HostName 100.73.15.5
  User dbochman
  IdentityFile ~/.ssh/id_work_mbp
  IdentitiesOnly yes
  IdentityAgent none
  ControlMaster auto
  ControlPersist 10m
  ControlPath ~/.ssh/cm-%C
  ServerAliveInterval 20
  ServerAliveCountMax 3

# Friendly name matching the Tailscale hostname (resolves via MagicDNS).
Host work-mbp
  HostName work-mbp.tail3e55f9.ts.net
  User dbochman
  IdentityFile ~/.ssh/id_work_mbp
  IdentitiesOnly yes
  IdentityAgent none
  ServerAliveInterval 20
  ServerAliveCountMax 3

# Attach directly to the lpu-knowledge-base tmux session.
Host lpu-kb-container
  RequestTTY yes
  RemoteCommand exec tmux new-session -A -s lpu-kb -c /workspace/repos/lpu-knowledge-base

# Devcontainer on mydevvm, reached through the work laptop's existing GCP/IAP config.
# Port 22390 is published only on the VM's loopback interface.
Host lpu-kb-container devcontainer-devvm devc
  HostName 127.0.0.1
  User root
  Port 22390
  HostKeyAlias devcontainer-devvm
  ProxyCommand ssh work-mac "ssh -W %h:%p mydevvm"
  IdentityFile ~/.ssh/id_github
  IdentitiesOnly yes
  IdentityAgent none
  ControlMaster auto
  ControlPersist 10m
  ControlPath ~/.ssh/cm-%C
  ServerAliveInterval 30
  ServerAliveCountMax 3
  Compression no
  IPQoS none

# On the local MBP, id_launchd bypasses 1Password Touch ID prompts for Mini SSH.
Match originalhost dylans-mac-mini exec "test -f ~/.ssh/id_launchd"
  IdentityFile ~/.ssh/id_launchd
  IdentityAgent none

# On the work MBP, id_work_mbp bypasses 1Password agent for Dylan's Mac SSH.
Match originalhost dylans-mac exec "test -f ~/.ssh/id_work_mbp"
  IdentityFile ~/.ssh/id_work_mbp
  IdentityAgent none

# Dedicated key for work MBP, bypasses 1Password agent.
Match originalhost dylans-work-mbp exec "test -f ~/.ssh/id_work_mbp"
  IdentityFile ~/.ssh/id_work_mbp
  IdentityAgent none

# On the Mini, id_mini_to_mbp bypasses 1Password agent (hangs under launchd).
Match originalhost dylans-macbook-pro exec "test -f ~/.ssh/id_mini_to_mbp"
  IdentityFile ~/.ssh/id_mini_to_mbp
  IdentityAgent none

# Dylan's laptop uses a dedicated key for direct Crosstown access.
Match originalhost dylans-macbook-pro exec "test -f ~/.ssh/id_crosstown"
  IdentityFile ~/.ssh/id_crosstown
  IdentitiesOnly yes
  IdentityAgent none

# 1Password SSH Agent (default for all other hosts)
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# GitHub
Host github.com
  HostName github.com
  User git
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
