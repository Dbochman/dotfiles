# Mac Mini (via Tailscale)
# On the launchd host (MBP), id_launchd bypasses 1Password Touch ID prompts.
# On other machines, falls through to the 1Password agent (Host * block).
Host dylans-mac-mini
  HostName dylans-mac-mini
  User dbochman
  Match host dylans-mac-mini exec "test -f ~/.ssh/id_launchd"
    IdentityFile ~/.ssh/id_launchd
    IdentityAgent none

# MacBook Pro at 19 Crosstown (via Tailscale)
Host dylans-macbook-pro
  HostName 100.107.209.85
  User dbochman

# 1Password SSH Agent
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# GitHub
Host github.com
  HostName github.com
  User git
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
