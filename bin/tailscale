#!/bin/sh
# Use the CLI bundled with the active macOS Tailscale app so the client and
# network-extension daemon always share the exact same build.
set -eu

app_cli="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
if [ ! -x "$app_cli" ]; then
  echo "tailscale: matching macOS app CLI not found at $app_cli" >&2
  exit 127
fi

export TAILSCALE_BE_CLI=1
exec "$app_cli" "$@"
