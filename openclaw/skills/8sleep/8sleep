#!/bin/bash
# 8sleep — control Eight Sleep Pod(s)
# Talks to Eight Sleep cloud API via 8sleep-api.py
# Supports both sides: Dylan (left) and Julia (right)
# Supports multi-Pod accounts via --location <crosstown|cabin> (default: crosstown)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
API_SCRIPT="$SCRIPT_DIR/8sleep-api.py"
PYTHON="/usr/bin/python3"

# Pop --location/-l from argv (accepted anywhere) and stash for run_api.
LOCATION_ARGS=()
REMAINING=()
i=1
while [[ $i -le $# ]]; do
  arg="${!i}"
  case "$arg" in
    -l|--location)
      next=$((i + 1))
      if [[ $next -gt $# ]]; then
        echo "Error: --location requires a value" >&2
        exit 1
      fi
      LOCATION_ARGS=(--location "${!next}")
      i=$((i + 2))
      ;;
    --location=*)
      LOCATION_ARGS=(--location "${arg#--location=}")
      i=$((i + 1))
      ;;
    *)
      REMAINING+=("$arg")
      i=$((i + 1))
      ;;
  esac
done
# bash 3.x (macOS default): expanding empty arrays under `set -u` is an error;
# `${arr[@]+"${arr[@]}"}` expands to nothing when arr is empty and to the
# array's elements otherwise.
set -- ${REMAINING[@]+"${REMAINING[@]}"}

run_api() {
  "$PYTHON" "$API_SCRIPT" ${LOCATION_ARGS[@]+"${LOCATION_ARGS[@]}"} "$@" 2>&1
}

parse_status() {
  python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response')
    sys.exit(1)
if 'error' in d:
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}')
    sys.exit(1)

dev = d.get('device', {})
print(f'Eight Sleep Pod ({dev.get(\"model\", \"?\")})')
print(f'  Connected: {\"Yes\" if dev.get(\"connected\") else \"No\"}')
print(f'  Water: {\"OK\" if dev.get(\"hasWater\") else \"LOW\"}')
print()

for name, key in [('Dylan (left)', 'dylan'), ('Julia (right)', 'julia')]:
    s = d.get(key, {})
    level = s.get('currentLevel', '?')
    target = s.get('targetLevel', '?')
    heating = s.get('heating', False)
    action = 'Heating' if heating and isinstance(level, int) and level > 0 else 'Cooling' if heating else 'Idle'
    # Approximate temp
    temp_f = round(55 + (level + 100) * (111 - 55) / 200) if isinstance(level, int) else '?'
    print(f'{name}:')
    print(f'  Level:  {level} (~{temp_f}F)')
    print(f'  Target: {target}')
    print(f'  Status: {action}')
    print()

sched = d.get('schedule', {})
if sched.get('type') == 'smart':
    smart = sched.get('smart', {})
    print(f'Dylan Smart Schedule: bedtime={smart.get(\"bedTimeLevel\",\"?\")}, initial={smart.get(\"initialSleepLevel\",\"?\")}, final={smart.get(\"finalSleepLevel\",\"?\")}')
"
}

parse_device() {
  python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response')
    sys.exit(1)
if 'error' in d:
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}')
    sys.exit(1)
print(f'Model:          {d.get(\"model\",\"?\")} ({d.get(\"size\",\"?\")})')
print(f'Serial:         {d.get(\"serial\",\"?\")}')
print(f'HW Revision:    {d.get(\"hwRevision\",\"?\")}')
print(f'Connected:      {\"Yes\" if d.get(\"connected\") else \"No\"}')
print(f'Last Connected: {d.get(\"lastConnected\",\"?\")}')
print(f'Water:          {\"OK\" if d.get(\"hasWater\") else \"LOW\"}')
print(f'Needs Priming:  {\"Yes\" if d.get(\"needsPriming\") else \"No\"}')
print(f'LED Brightness: {d.get(\"ledBrightness\",\"?\")}')
"
}

parse_temp_set() {
  python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response')
    sys.exit(1)
if 'error' in d:
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}')
    sys.exit(1)
side = d.get('side', '?')
level = d.get('level', '?')
if isinstance(level, int):
    temp_f = round(55 + (level + 100) * (111 - 55) / 200)
    print(f'{side.title()} side set to level {level} (~{temp_f}F)')
else:
    print(f'{side.title()} side set to level {level}')
"
}

parse_sleep() {
  python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response')
    sys.exit(1)
if 'error' in d:
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}')
    sys.exit(1)
side = d.get('side', '?')
days = d.get('days', [])
if not days:
    print(f'{side.title()}: No sleep data available')
    sys.exit(0)
for day in days:
    date = day.get('day', '?')
    score = day.get('score', '?')
    duration_min = round(day.get('sleepDuration', 0) / 60)
    hours = duration_min // 60
    mins = duration_min % 60
    rem_pct = round(day.get('remPercent', 0) * 100)
    deep_pct = round(day.get('deepPercent', 0) * 100)
    snore_min = round(day.get('snoreDuration', 0) / 60)
    print(f'{side.title()} — {date}:')
    print(f'  Sleep Score:   {score}')
    print(f'  Duration:      {hours}h {mins}m')
    print(f'  REM:           {rem_pct}%')
    print(f'  Deep:          {deep_pct}%')
    if snore_min > 0:
        print(f'  Snoring:       {snore_min} min')
    print()
"
}

case "${1:-}" in
  status)
    run_api status | parse_status
    ;;
  temp)
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then
      echo "Usage: 8sleep temp <dylan|julia> <level>" >&2
      echo "  Level: -100 (55F/cold) to +100 (111F/hot)" >&2
      echo "  Examples: -50 (cool), 0 (neutral), +30 (warm)" >&2
      exit 1
    fi
    run_api temp "$2" "$3" | parse_temp_set
    ;;
  device)
    run_api device | parse_device
    ;;
  sleep)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: 8sleep sleep <dylan|julia> [YYYY-MM-DD]" >&2
      exit 1
    fi
    run_api sleep "$2" "${3:-}" | parse_sleep
    ;;
  off)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: 8sleep off <dylan|julia>" >&2
      echo "  Turns off thermal unit for a side (stops heating/cooling)" >&2
      exit 1
    fi
    run_api off "$2" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response'); sys.exit(1)
if 'error' in d and not d.get('success'):
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}'); sys.exit(1)
print(f'{d.get(\"side\",\"?\").title()} side turned OFF')
"
    ;;
  on)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: 8sleep on <dylan|julia>" >&2
      echo "  Turns on thermal unit for a side (resumes smart schedule)" >&2
      exit 1
    fi
    run_api on "$2" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response'); sys.exit(1)
if 'error' in d and not d.get('success'):
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}'); sys.exit(1)
print(f'{d.get(\"side\",\"?\").title()} side turned ON (smart schedule resumed)')
"
    ;;
  home)
    if [[ -z "${2:-}" || "${#LOCATION_ARGS[@]}" -eq 0 ]]; then
      echo "Usage: 8sleep --location <crosstown|cabin> home <dylan|julia>" >&2
      echo "  Makes that Pod current for the user; the other Pod becomes away" >&2
      exit 1
    fi
    run_api home "$2" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response'); sys.exit(1)
expected_side = sys.argv[1].lower()
expected_location = sys.argv[2].lower()
if 'error' in d and not d.get('success'):
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}'); sys.exit(1)
if (d.get('success') is not True or d.get('state') != 'home'
        or str(d.get('side', '')).lower() != expected_side
        or str(d.get('location', '')).lower() != expected_location):
    print('Error: Eight Sleep home verification returned an invalid response')
    sys.exit(1)
side = d.get('side', '?').title()
location = d.get('location', '?').title()
changed = 'updated' if d.get('changed') else 'already current'
print(f'{side} home at {location} ({changed})')
" "$2" "${LOCATION_ARGS[1]}"
    ;;
  away)
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then
      echo "Usage: 8sleep away <dylan|julia> <start|end>" >&2
      echo "  start = enable away mode (extended absence)" >&2
      echo "  end   = disable away mode on the already-current Pod" >&2
      exit 1
    fi
    run_api away "$2" "$3" | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response'); sys.exit(1)
if 'error' in d and not d.get('success'):
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}'); sys.exit(1)
action = d.get('away', '?')
side = d.get('side', '?').title()
if action == 'start':
    print(f'{side} away mode ENABLED')
else:
    print(f'{side} away mode DISABLED')
"
    ;;
  raw)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: 8sleep raw <api-path>" >&2
      exit 1
    fi
    run_api raw "$2" | python3 -m json.tool
    ;;
  *)
    echo "Usage: 8sleep [--location <name>] <command>"
    echo ""
    echo "Commands:"
    echo "  status                          Pod status (both sides: temp, heating, water)"
    echo "  temp <dylan|julia> <level>      Set side temp (-100 cold to +100 hot)"
    echo "  off <dylan|julia>               Turn off side (stop thermal unit)"
    echo "  on <dylan|julia>                Turn on side (resume smart schedule)"
    echo "  home <dylan|julia>              With explicit --location, make that Pod current"
    echo "  away <dylan|julia> start|end    Start/end away mode (extended absence)"
    echo "  device                          Device info (model, water, connectivity)"
    echo "  sleep <dylan|julia> [date]      Sleep data (default: last night)"
    echo "  raw <path>                      Raw API GET"
    echo ""
    echo "Locations: crosstown (default), cabin"
    echo "Sides: dylan (left), julia (right)"
    echo ""
    echo "Temperature scale:"
    echo "  -100 = 55F (very cold)    -50 = 70F (cool)"
    echo "     0 = 81F (neutral)      +50 = 97F (warm)"
    echo "  +100 = 111F (very hot)"
    exit 1
    ;;
esac
