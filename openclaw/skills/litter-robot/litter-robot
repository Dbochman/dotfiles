#!/bin/bash
# litter-robot — control Litter-Robot 4 at Crosstown

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
API_SCRIPT="$SCRIPT_DIR/litter-robot-api.py"
PYTHON="$HOME/.openclaw/litter-robot/venv/bin/python3"

run_api() { "$PYTHON" "$API_SCRIPT" "$@" 2>&1; }

parse_status() {
  python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response')
    sys.exit(1)
if 'error' in d:
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}')
    sys.exit(1)

for r in d.get('robots', []):
    status = r.get('status', '?')
    waste = r.get('wasteLevel', '?')
    online = 'Online' if r.get('isOnline') else 'Offline'
    full = ' (FULL!)' if r.get('isWasteFull') else ''
    print(f'{r.get(\"name\", \"?\")} ({r.get(\"model\", \"?\")}) — {online}')
    print(f'  Status:      {status}')
    print(f'  Waste Level: {waste}%{full}')
    print(f'  Night Light: {\"On\" if r.get(\"nightLight\") else \"Off\"}')
    print(f'  Panel Lock:  {\"On\" if r.get(\"panelLock\") else \"Off\"}')
    print(f'  Clean Wait:  {r.get(\"cleanWaitMinutes\", \"?\")} min')
    cc = r.get('cycleCount')
    cap = r.get('cycleCapacity')
    if cc is not None:
        print(f'  Cycles:      {cc}' + (f' / {cap}' if cap else ''))
    print()

pets = d.get('pets', [])
if pets:
    print('Cats:')
    for p in pets:
        print(f'  {p.get(\"name\", \"?\")} — {p.get(\"weight\", \"?\")} lbs')
"
}

parse_action() {
  python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
except:
    print('Error: Could not parse response')
    sys.exit(1)
if 'error' in d:
    print(f'Error: {d.get(\"message\", d.get(\"error\"))}')
    sys.exit(1)
action = d.get('action', 'done')
robot = d.get('robot', '?')
print(f'{robot}: {action.replace(\"_\", \" \").title()}')
"
}

case "${1:-}" in
  status)
    run_api status | parse_status
    ;;
  clean)
    run_api clean | parse_action
    ;;
  history)
    run_api history "${2:-10}" | python3 -m json.tool
    ;;
  pets)
    run_api pets | python3 -m json.tool
    ;;
  nightlight)
    if [[ -z "${2:-}" ]]; then
      echo "Usage: litter-robot nightlight <on|off>" >&2
      exit 1
    fi
    run_api nightlight "$2" | parse_action
    ;;
  reset)
    run_api reset | parse_action
    ;;
  *)
    echo "Usage: litter-robot <command>"
    echo ""
    echo "Commands:"
    echo "  status              Robot status, waste level, cats"
    echo "  clean               Start a cleaning cycle"
    echo "  history [N]         Activity history (default: 10)"
    echo "  pets                Cat info and weights"
    echo "  nightlight <on|off> Toggle night light"
    echo "  reset               Reset waste drawer gauge"
    exit 1
    ;;
esac
