#!/bin/bash
# Refresh OpenClaw secrets cache from 1Password.
# Run this over SSH or interactively when op read works.
# Usage: ssh dylans-mac-mini ~/bin/openclaw-refresh-secrets
set -euo pipefail

export HOME="/Users/dbochman"
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
export OP_SERVICE_ACCOUNT_TOKEN=$(cat "$HOME/.openclaw/.env-token")

CACHE="$HOME/.openclaw/.secrets-cache"
CACHE_DIR=$(dirname "$CACHE")
TMP=$(mktemp "$CACHE_DIR/.secrets-cache.XXXXXX")
trap 'rm -f "$TMP"' EXIT

read_required() {
  local variable="$1"
  local reference="$2"
  local value

  if ! value=$(/opt/homebrew/bin/op read "$reference"); then
    echo "Unable to refresh required secret $variable; existing cache preserved." >&2
    exit 1
  fi
  if [[ -z "$value" ]]; then
    echo "Required secret $variable is empty; existing cache preserved." >&2
    exit 1
  fi
  printf -v "$variable" '%s' "$value"
}

read_plaid_note_field() {
  local label="$1"
  local value

  value=$(printf '%s\n' "$PLAID_NOTES" | awk -v wanted="$label" '
    BEGIN { IGNORECASE = 1 }
    index($0, ":") {
      field = $0
      sub(/:.*/, "", field)
      if (tolower(field) == tolower(wanted)) {
        sub(/^[^:]*:[[:space:]]*/, "")
        print
        exit
      }
    }
  ')
  if [[ -z "$value" ]]; then
    echo "Required Plaid field $label is missing; existing cache preserved." >&2
    exit 1
  fi
  printf '%s' "$value"
}

read_required OPENAI_API_KEY 'op://OpenClaw/OpenAI API Key/password'
# These IDs disambiguate duplicate historical items with identical values.
read_required ELEVENLABS_API_KEY 'op://OpenClaw/7aw52h2uwa3h5gcg5yretvy3ky/password'
read_required OPENCLAW_GATEWAY_TOKEN 'op://OpenClaw/2wgcorrdiccix2ybjucrvkbeq4/password'
read_required BLUEBUBBLES_PASSWORD 'op://OpenClaw/BlueBubbles Password/password'
read_required CIELO_USERNAME 'op://OpenClaw/Cielo Login/username'
read_required CIELO_PASSWORD 'op://OpenClaw/Cielo Login/password'
read_required STARMARKET_PASSWORD 'op://OpenClaw/Star Market/password'
read_required STARMARKET_USERNAME 'op://OpenClaw/Star Market/username'
read_required RENTCAST_API_KEY 'op://OpenClaw/RentCast/password'
read_required PLAID_NOTES 'op://OpenClaw/Plaid/notesPlain'
PLAID_CLIENT_ID=$(read_plaid_note_field 'Client ID')
PLAID_SECRET_PRODUCTION=$(read_plaid_note_field 'Production Secret')
PLAID_SECRET_SANDBOX=$(read_plaid_note_field 'Sandbox secret')

echo "Fetching secrets from 1Password..."
{
  echo "OPENAI_API_KEY=$OPENAI_API_KEY"
  echo "ELEVENLABS_API_KEY=$ELEVENLABS_API_KEY"
  echo "OPENCLAW_GATEWAY_TOKEN=$OPENCLAW_GATEWAY_TOKEN"
  echo "BLUEBUBBLES_PASSWORD=$BLUEBUBBLES_PASSWORD"
  echo "CIELO_USERNAME=$CIELO_USERNAME"
  echo "CIELO_PASSWORD=$CIELO_PASSWORD"
  if MYSA_USERNAME=$(/opt/homebrew/bin/op read 'op://OpenClaw/4j3ywjm4xmwre76yliojk5xyta/username' 2>/dev/null) && \
     MYSA_PASSWORD=$(/opt/homebrew/bin/op read 'op://OpenClaw/4j3ywjm4xmwre76yliojk5xyta/password' 2>/dev/null) && \
     [[ -n "$MYSA_USERNAME" && -n "$MYSA_PASSWORD" ]]; then
    printf 'MYSA_USERNAME=%q\n' "$MYSA_USERNAME"
    printf 'MYSA_PASSWORD=%q\n' "$MYSA_PASSWORD"
  else
    echo "Mysa credential is not present or incomplete; skipping Mysa credential cache." >&2
  fi
  echo "STARMARKET_PASSWORD=$STARMARKET_PASSWORD"
  echo "STARMARKET_USERNAME=$STARMARKET_USERNAME"
  printf 'RENTCAST_API_KEY=%q\n' "$RENTCAST_API_KEY"
  printf 'PLAID_CLIENT_ID=%s\n' "$PLAID_CLIENT_ID"
  printf 'PLAID_SECRET_PRODUCTION=%s\n' "$PLAID_SECRET_PRODUCTION"
  printf 'PLAID_SECRET_SANDBOX=%s\n' "$PLAID_SECRET_SANDBOX"
  # Static Star Market config (not in 1Password — these are account-specific identifiers, not rotatable secrets)
  echo "STARMARKET_GMAIL=julia.joy.jennings@gmail.com"
  echo "STARMARKET_USER_HASH=29fb95f3f8a30a41fb17ac7e74543649e5a69d54e423d2ba66a91d67a28918bb"
  echo "STARMARKET_DEVICE_TOKEN=0bbf660dcdd2bed236a204f4eaa54bb6"
  # Eight Sleep Pod — well-known APK client creds + user IDs from device API
  echo "EIGHTSLEEP_CLIENT_ID=0894c7f33bb94800a03f1f4df13a4f38"
  echo "EIGHTSLEEP_CLIENT_SECRET=f0954a3ed5763ba3d06834c73731a32f15f168f47d4f164751275def86db0c76"
  echo "EIGHTSLEEP_DYLAN_USER_ID=9ce2e82f950545969b18164ed79feeea"
  echo "EIGHTSLEEP_JULIA_USER_ID=65012cc935d6472291c0b7324c8b12b6"
  # Petlibro — well-known app constant from HA integration
  echo "PETLIBRO_APPSN=c35772530d1041699c87fe62348507a8"
  # Cielo AC — static API key from Cielo app
  echo "CIELO_API_KEY=3iCWYuBqpY2g7yRq3yyTk1XCS4CMjt1n9ECCjdpd"
  # Fi collar (Potato) — auth via tryfi.com "Forgot Password" flow
  echo "TRYFI_EMAIL=dylanbochman@gmail.com"
  echo 'TRYFI_PASSWORD=8Oc#m@n!'
  # Home coordinates for Fi geofencing + presence + dog walk
  echo "CROSSTOWN_LAT=42.26233696"
  echo "CROSSTOWN_LON=-71.16434947"
  echo "CABIN_LAT=42.60211154"
  echo "CABIN_LON=-72.15119056"
} > "$TMP"

mv "$TMP" "$CACHE"
chmod 600 "$CACHE"
trap - EXIT
echo "Secrets cached to $CACHE ($(wc -c < "$CACHE") bytes)"
echo "Restart the gateway to pick up changes: launchctl stop ai.openclaw.gateway && launchctl start ai.openclaw.gateway"
