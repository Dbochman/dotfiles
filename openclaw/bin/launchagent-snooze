#!/usr/bin/env bash

set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  launchagent-snooze pause [--for DURATION]
  launchagent-snooze pause --manual
  launchagent-snooze snooze DURATION
  launchagent-snooze status
  launchagent-snooze resume

Durations: 30m, 2h, or 1h30m (minimum 1 minute, maximum 7 days).
EOF
}

parse_duration() {
  local raw="$1"
  local hours=0
  local minutes=0

  raw="$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -d '[:space:]')"
  case "$raw" in
    *hours) raw="${raw%hours}h" ;;
    *hour) raw="${raw%hour}h" ;;
    *hrs) raw="${raw%hrs}h" ;;
    *hr) raw="${raw%hr}h" ;;
    *minutes) raw="${raw%minutes}m" ;;
    *minute) raw="${raw%minute}m" ;;
    *mins) raw="${raw%mins}m" ;;
    *min) raw="${raw%min}m" ;;
  esac

  if [[ "$raw" =~ ^([0-9]+)h([0-9]+)m$ ]]; then
    hours=$((10#${BASH_REMATCH[1]}))
    minutes=$((10#${BASH_REMATCH[2]}))
  elif [[ "$raw" =~ ^([0-9]+)h$ ]]; then
    hours=$((10#${BASH_REMATCH[1]}))
  elif [[ "$raw" =~ ^([0-9]+)m$ ]]; then
    minutes=$((10#${BASH_REMATCH[1]}))
  else
    echo "Invalid duration: $1" >&2
    usage >&2
    return 2
  fi

  local seconds=$((hours * 3600 + minutes * 60))
  if (( seconds < 60 || seconds > 604800 )); then
    echo "Duration must be between 1 minute and 7 days: $1" >&2
    return 2
  fi

  printf '%s\n' "$seconds"
}

action="${1:-}"
[[ -n "$action" ]] || {
  usage >&2
  exit 2
}
shift

duration_seconds=""
manual_timer=0
from_timer=0

case "$action" in
  snooze)
    action="pause"
    [[ $# -eq 1 ]] || {
      usage >&2
      exit 2
    }
    duration_seconds="$(parse_duration "$1")"
    ;;
  pause)
    case $# in
      0) ;;
      1)
        if [[ "$1" == "--manual" ]]; then
          manual_timer=1
        else
          duration_seconds="$(parse_duration "$1")"
        fi
        ;;
      2)
        [[ "$1" == "--for" ]] || {
          usage >&2
          exit 2
        }
        duration_seconds="$(parse_duration "$2")"
        ;;
      *)
        usage >&2
        exit 2
        ;;
    esac
    ;;
  status)
    [[ $# -eq 0 ]] || {
      usage >&2
      exit 2
    }
    ;;
  resume)
    if [[ $# -eq 1 && "$1" == "--from-timer" ]]; then
      from_timer=1
    elif [[ $# -ne 0 ]]; then
      usage >&2
      exit 2
    fi
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

hostname_short="$(hostname -s 2>/dev/null || hostname)"
case "$hostname_short" in
  Dylans-Mac-mini*|dylans-mac-mini*) ;;
  *)
    if [[ "${LAUNCHAGENT_SNOOZE_ALLOW_ANY_HOST:-0}" != "1" ]]; then
      echo "Refusing to manage Mac Mini LaunchAgents on host: $hostname_short" >&2
      exit 1
    fi
    ;;
esac

labels=(
  ai.openclaw.boa-keepalive
  ai.openclaw.boa-browser-heartbeat
  com.openclaw.cielo-refresh
)

uid="$(id -u)"
domain="gui/$uid"
state_dir="$HOME/.openclaw/state"
state_file="$state_dir/mac-mini-automation-snooze.tsv"
timer_label="com.openclaw.launchagent-snooze-resume"
timer_plist="$HOME/Library/LaunchAgents/$timer_label.plist"
timer_log="$HOME/.openclaw/logs/launchagent-snooze.log"
cli_path="$HOME/.openclaw/bin/launchagent-snooze"

is_loaded() {
  launchctl print "$domain/$1" >/dev/null 2>&1
}

is_disabled() {
  launchctl print-disabled "$domain" 2>/dev/null \
    | grep -Fq '"'"$1"'" => disabled'
}

state_value() {
  local key="$1"
  [[ -f "$state_file" ]] || return 0
  awk -F '\t' -v key="$key" '$1 == key { print $2; exit }' "$state_file"
}

rewrite_timer_metadata() {
  local resume_at="${1:-}"
  local seconds="${2:-}"
  local tmp_file

  [[ -f "$state_file" ]] || return 1
  tmp_file="$(mktemp "$state_file.XXXXXX")"
  awk -F '\t' '$1 != "resume_at" && $1 != "duration_seconds"' "$state_file" > "$tmp_file"
  if [[ -n "$resume_at" ]]; then
    printf 'resume_at\t%s\nduration_seconds\t%s\n' "$resume_at" "$seconds" >> "$tmp_file"
  fi
  chmod 600 "$tmp_file"
  mv "$tmp_file" "$state_file"
}

cancel_timer() {
  rm -f "$timer_plist"
  launchctl bootout "$domain/$timer_label" >/dev/null 2>&1 || true
}

schedule_timer() {
  local seconds="$1"
  local new_plist
  local old_plist=""
  local resume_at

  mkdir -p "$HOME/Library/LaunchAgents" "$(dirname "$timer_log")"
  new_plist="$(mktemp "$timer_plist.XXXXXX")"

  if [[ -f "$timer_plist" ]]; then
    old_plist="$(mktemp "$timer_plist.backup.XXXXXX")"
    cp "$timer_plist" "$old_plist"
  fi

  resume_at="$(/usr/bin/python3 - "$new_plist" "$seconds" "$timer_label" "$cli_path" "$timer_log" <<'PY'
from datetime import datetime, timedelta
import plistlib
import sys
import time

path, seconds, label, cli_path, log_path = sys.argv[1:]
deadline = datetime.fromtimestamp(time.time() + int(seconds)).astimezone()
deadline = (deadline + timedelta(seconds=59)).replace(second=0, microsecond=0)

payload = {
    "Label": label,
    "ProgramArguments": [cli_path, "resume", "--from-timer"],
    "StartCalendarInterval": {
        "Month": deadline.month,
        "Day": deadline.day,
        "Hour": deadline.hour,
        "Minute": deadline.minute,
    },
    "ProcessType": "Background",
    "StandardOutPath": log_path,
    "StandardErrorPath": log_path,
}

with open(path, "wb") as handle:
    plistlib.dump(payload, handle, fmt=plistlib.FMT_XML, sort_keys=False)

print(deadline.isoformat())
PY
)"

  plutil -lint "$new_plist" >/dev/null
  launchctl bootout "$domain/$timer_label" >/dev/null 2>&1 || true
  mv "$new_plist" "$timer_plist"
  chmod 600 "$timer_plist"

  if ! launchctl bootstrap "$domain" "$timer_plist"; then
    rm -f "$timer_plist"
    if [[ -n "$old_plist" && -f "$old_plist" ]]; then
      mv "$old_plist" "$timer_plist"
      launchctl bootstrap "$domain" "$timer_plist" >/dev/null 2>&1 || true
    fi
    echo "Failed to schedule automatic resume; manual snooze remains active." >&2
    return 1
  fi

  if ! rewrite_timer_metadata "$resume_at" "$seconds"; then
    cancel_timer
    if [[ -n "$old_plist" && -f "$old_plist" ]]; then
      mv "$old_plist" "$timer_plist"
      launchctl bootstrap "$domain" "$timer_plist" >/dev/null 2>&1 || true
    fi
    echo "Failed to record automatic resume; timer was rolled back." >&2
    return 1
  fi

  [[ -z "$old_plist" ]] || rm -f "$old_plist"
  echo "Automatic resume scheduled for $resume_at."
}

show_status() {
  local created_at=""
  local resume_at=""

  if [[ -f "$state_file" ]]; then
    created_at="$(state_value created_at)"
    resume_at="$(state_value resume_at)"
    echo "snooze: active${created_at:+ since $created_at}"
    if [[ -n "$resume_at" ]]; then
      if is_loaded "$timer_label"; then
        echo "automatic resume: $resume_at (scheduled)"
      else
        echo "automatic resume: $resume_at (timer missing)"
      fi
    else
      echo "automatic resume: not scheduled"
    fi
  else
    echo "snooze: inactive"
  fi

  for label in "${labels[@]}"; do
    loaded="unloaded"
    override="enabled"
    is_loaded "$label" && loaded="loaded"
    is_disabled "$label" && override="disabled"
    printf '%s: %s, %s\n' "$label" "$loaded" "$override"
  done
}

case "$action" in
  pause)
    mkdir -p "$state_dir"
    chmod 700 "$state_dir"

    if [[ -f "$state_file" ]]; then
      echo "Snooze is already active; preserving its original restore set."
      if [[ -n "$duration_seconds" ]]; then
        schedule_timer "$duration_seconds"
      elif (( manual_timer != 0 )); then
        cancel_timer
        rewrite_timer_metadata
        echo "Automatic resume canceled; snooze remains active."
      fi
      show_status
      exit 0
    fi

    tmp_file="$(mktemp "$state_file.XXXXXX")"
    trap 'rm -f "$tmp_file"' EXIT
    printf 'version\t1\ncreated_at\t%s\n' "$(date -u '+%Y-%m-%dT%H:%M:%SZ')" > "$tmp_file"

    for label in "${labels[@]}"; do
      if ! is_loaded "$label"; then
        echo "$label: already unloaded; leaving its override unchanged"
        continue
      fi

      launchctl disable "$domain/$label"
      if launchctl bootout "$domain/$label"; then
        printf 'label\t%s\n' "$label" >> "$tmp_file"
        echo "$label: paused"
      else
        launchctl enable "$domain/$label" || true
        echo "$label: failed to unload; rolled back its disabled override" >&2
        exit 1
      fi
    done

    chmod 600 "$tmp_file"
    mv "$tmp_file" "$state_file"
    trap - EXIT

    if [[ -n "$duration_seconds" ]]; then
      schedule_timer "$duration_seconds"
    fi
    show_status
    ;;

  status)
    show_status
    ;;

  resume)
    if [[ ! -f "$state_file" ]]; then
      cancel_timer
      echo "No active snooze state; nothing to restore."
      show_status
      exit 0
    fi

    failed=0
    while IFS=$'\t' read -r key label; do
      [[ "$key" == "label" ]] || continue
      plist="$HOME/Library/LaunchAgents/$label.plist"

      if [[ ! -f "$plist" ]]; then
        echo "$label: plist missing at $plist" >&2
        failed=1
        continue
      fi

      launchctl enable "$domain/$label"
      if is_loaded "$label" || launchctl bootstrap "$domain" "$plist"; then
        echo "$label: restored"
      else
        launchctl disable "$domain/$label" || true
        echo "$label: restore failed; kept disabled" >&2
        failed=1
      fi
    done < "$state_file"

    if (( failed != 0 )); then
      echo "Snooze state retained because one or more jobs failed to restore." >&2
      if (( from_timer != 0 )); then
        cancel_timer
      fi
      exit 1
    fi

    rm -f "$state_file"
    echo "Snooze ended."
    show_status
    cancel_timer
    ;;
esac
