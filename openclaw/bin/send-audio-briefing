#!/usr/bin/env python3
"""send-audio-briefing — Generate TTS audio from text and send via iMessage.

Usage:
  send-audio-briefing <target> "text to speak"
  send-audio-briefing <target> "text" --message "Short summary"
  send-audio-briefing <target> "text" --voice Jessica --message "Summary"
  echo "text" | send-audio-briefing <target>

Requires: sag-wrapper and imsg.
"""

import argparse
import json
import os
import subprocess
import sys
import tempfile

SAG_WRAPPER = "/opt/homebrew/bin/sag-wrapper"
IMSG_BIN = "/opt/homebrew/bin/imsg"


def generate_audio(text: str, voice: str, output_path: str) -> bool:
    """Generate TTS audio via sag-wrapper."""
    cmd = [SAG_WRAPPER, "-o", output_path, "--play=false", "-v", voice, text]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        print(f"TTS error: {result.stderr}", file=sys.stderr)
        return False
    if not os.path.exists(output_path) or os.path.getsize(output_path) == 0:
        print("TTS produced no output", file=sys.stderr)
        return False
    size = os.path.getsize(output_path)
    print(f"Audio generated: {size} bytes ({voice})", file=sys.stderr)
    return True


def run_imsg(args: list[str], timeout: int) -> dict:
    """Run imsg and return its JSON response."""
    result = subprocess.run(
        [IMSG_BIN, *args, "--json"],
        capture_output=True,
        text=True,
        timeout=timeout,
    )
    if result.returncode != 0:
        raise RuntimeError(result.stderr.strip() or result.stdout.strip())
    return json.loads(result.stdout)


def target_send_args(target: str) -> list[str]:
    """Map OpenClaw-style iMessage targets to imsg send arguments."""
    if target.startswith("chat_id:"):
        return ["--chat-id", target.removeprefix("chat_id:")]
    if target.startswith("chat_guid:"):
        return ["--chat-guid", target.removeprefix("chat_guid:")]
    if target.startswith("chat_identifier:"):
        return ["--chat-identifier", target.removeprefix("chat_identifier:")]
    if ";-;" in target or ";+;" in target:
        return ["--chat-guid", target]
    return ["--to", target]


def target_attachment_chat(target: str) -> str | None:
    """Resolve a target to the chat GUID required by imsg send-attachment."""
    if target.startswith("chat_id:"):
        resp = run_imsg(["group", "--chat-id", target.removeprefix("chat_id:")], timeout=10)
        return resp.get("guid")
    if target.startswith("chat_guid:"):
        return target.removeprefix("chat_guid:")
    if ";-;" in target or ";+;" in target:
        return target
    return None


def send_attachment(target: str, audio_path: str) -> bool:
    """Send audio file via imsg."""
    try:
        chat_guid = target_attachment_chat(target)
        if chat_guid:
            resp = run_imsg(
                ["send-attachment", "--chat", chat_guid, "--file", audio_path, "--audio"],
                timeout=60,
            )
        else:
            resp = run_imsg(
                ["send", *target_send_args(target), "--file", audio_path],
                timeout=60,
            )
    except (subprocess.TimeoutExpired, RuntimeError, json.JSONDecodeError) as exc:
        print(f"Attachment send failed: {exc}", file=sys.stderr)
        return False
    print(f"Audio sent to {target}", file=sys.stderr)
    return resp.get("status") in {"sent", "ok", "success"} or bool(resp.get("guid") or resp.get("message_id"))


def send_text(target: str, message: str) -> bool:
    """Send summary text via imsg."""
    try:
        resp = run_imsg(
            ["send", *target_send_args(target), "--text", message],
            timeout=20,
        )
    except (subprocess.TimeoutExpired, RuntimeError, json.JSONDecodeError) as exc:
        print(f"Text send failed: {exc}", file=sys.stderr)
        return False
    print("Summary text sent", file=sys.stderr)
    return resp.get("status") == "sent"


def main():
    parser = argparse.ArgumentParser(description="Generate TTS audio and send via iMessage")
    parser.add_argument(
        "target",
        help="iMessage target, preferably chat_id:<id>; also accepts chat_guid:<guid>, a raw chat GUID, phone, or email",
    )
    parser.add_argument("text", nargs="?", default="", help="Text to speak (or pipe via stdin)")
    parser.add_argument("-m", "--message", default="", help="Short summary text to send after audio")
    parser.add_argument("-v", "--voice", default="Sarah", help="ElevenLabs voice (default: Sarah)")
    args = parser.parse_args()

    text = args.text
    if not text:
        if not sys.stdin.isatty():
            text = sys.stdin.read().strip()
    if not text:
        print("Error: no text provided", file=sys.stderr)
        sys.exit(1)

    # Generate audio
    with tempfile.NamedTemporaryFile(suffix=".mp3", delete=False) as tmp:
        audio_path = tmp.name

    try:
        if not generate_audio(text, args.voice, audio_path):
            sys.exit(1)

        # Send audio attachment
        if not send_attachment(args.target, audio_path):
            sys.exit(1)

        # Send summary text if provided
        if args.message:
            send_text(args.target, args.message)

        print(json.dumps({"ok": True}))
    finally:
        try:
            os.unlink(audio_path)
        except OSError:
            pass


if __name__ == "__main__":
    main()
