#!/usr/bin/env bash
# Keep a remote tmux client attached across laptop sleep and network changes.

set -o pipefail

usage() {
  echo "Usage: cmux-ssh-tmux <ssh-host> <tmux-session> [tmux-binary]" >&2
}

if [[ $# -lt 2 || $# -gt 3 ]]; then
  usage
  exit 2
fi

host="$1"
session="$2"
tmux_bin="${3:-tmux}"
ssh_bin="${CMUX_SSH_TMUX_SSH_BIN:-/usr/bin/ssh}"
retry_delay="${CMUX_SSH_TMUX_RETRY_DELAY:-2}"
max_retry_delay="${CMUX_SSH_TMUX_MAX_RETRY_DELAY:-15}"

if [[ "$host" == -* || "$host" == *[[:space:]]* ]]; then
  echo "cmux-ssh-tmux: invalid SSH host: $host" >&2
  exit 2
fi

if [[ ! "$session" =~ ^[A-Za-z0-9_.-]+$ ]]; then
  echo "cmux-ssh-tmux: invalid tmux session name: $session" >&2
  exit 2
fi

if [[ ! "$tmux_bin" =~ ^[A-Za-z0-9_./+-]+$ ]]; then
  echo "cmux-ssh-tmux: invalid tmux binary: $tmux_bin" >&2
  exit 2
fi

if [[ ! -x "$ssh_bin" ]]; then
  echo "cmux-ssh-tmux: SSH binary is not executable: $ssh_bin" >&2
  exit 127
fi

case "$retry_delay:$max_retry_delay" in
  *[!0-9:]*|:*|*:)
    echo "cmux-ssh-tmux: retry delays must be non-negative integers" >&2
    exit 2
    ;;
esac

stop_requested=0
request_stop() {
  stop_requested=1
}
trap request_stop INT TERM HUP

register_cmux_resume() {
  [[ -n "${CMUX_SURFACE_ID:-}" ]] || return 0
  command -v cmux >/dev/null 2>&1 || return 0

  local resume_command
  printf -v resume_command '%q %q %q %q' "$0" "$host" "$session" "$tmux_bin"
  cmux surface resume set \
    --kind tmux \
    --checkpoint "ssh-${host}-${session}" \
    --source cmux-ssh-tmux \
    --cwd "$HOME" \
    --shell "$resume_command" \
    >/dev/null 2>&1 || true
}

register_cmux_resume

delay="$retry_delay"
while (( ! stop_requested )); do
  started_at=$SECONDS
  "$ssh_bin" \
    -tt \
    -o ConnectTimeout=8 \
    -o ConnectionAttempts=1 \
    -o ServerAliveInterval=10 \
    -o ServerAliveCountMax=3 \
    -o ControlMaster=no \
    -o ControlPath=none \
    -- \
    "$host" \
    "$tmux_bin" new-session -A -s "$session"
  status=$?
  connected_for=$((SECONDS - started_at))

  (( stop_requested )) && exit 130

  # A clean detach or a real tmux error is final. OpenSSH reserves 255 for
  # connection/authentication failures, which are the only failures to retry.
  if (( status != 255 )); then
    exit "$status"
  fi

  # After a stable connection, start the backoff over. Brief failures ramp to
  # the cap so an offline host does not create a tight retry loop.
  if (( connected_for >= 30 )); then
    delay="$retry_delay"
  fi

  printf '\r\n[cmux] SSH to %s dropped; tmux session %q is still running remotely.\r\n' \
    "$host" "$session" >&2
  printf '[cmux] Reconnecting in %ss (Ctrl-C to stop)...\r\n' "$delay" >&2

  sleep "$delay" &
  wait $!
  (( stop_requested )) && exit 130

  if (( delay < max_retry_delay )); then
    delay=$((delay * 2))
    (( delay > max_retry_delay )) && delay="$max_retry_delay"
  fi
done

exit 130
