# Backup directory for sync operations (created by install.sh and sync.sh)
# Location: $DOTFILES_DIR/.backup/
.backup/

# Local-only settings (machine-specific, not synced)
.claude/settings.local.json

# Plugin marketplaces registry (contains machine-specific absolute installLocation
# paths; rewritten by Claude Code on every plugin op, causing constant churn).
# Re-add marketplaces on a fresh install via `/plugin marketplace add <repo>` —
# see install.sh "Plugins" section for the canonical list.
.claude/plugins/known_marketplaces.json

# Agent teams skills mirror (duplicates .claude/skills/, populated by experimental
# CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS feature)
.agents/

# Plans directory (temporary planning files)
.claude/plans/

# Claude session data (not config)
.claude/projects/-Users-dbochman/*.jsonl
.claude/projects/-Users-dbochman/*/
# But keep memory files
!.claude/projects/-Users-dbochman/memory/

# Skill local overrides (sensitive data like addresses, credentials references)
# Convention: SKILL.md is checked in, *.local.md is machine-local only
openclaw/skills/**/*.local.md

# Python bytecode
**/__pycache__/

# OS files
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
